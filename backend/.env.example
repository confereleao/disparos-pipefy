# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://disparos:disparos123@localhost:5432/disparos_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_troque_em_producao
JWT_EXPIRES_IN=7d

# Admin inicial (usado no seed)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrador

# Pipefy (configurado por integração, mas pode ter token padrão)
PIPEFY_API_URL=https://api.pipefy.com/graphql

# WhatsApp - Evolution API (configurado por integração)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution_api

# Rate limit de envio
DEFAULT_SEND_INTERVAL_MS=2000
DEFAULT_DAILY_LIMIT=500
DEFAULT_ALLOWED_HOURS_START=8
DEFAULT_ALLOWED_HOURS_END=20
